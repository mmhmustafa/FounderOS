{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://founderos.dev/contracts/opportunity-report-content.schema.json",
  "title": "FounderOS Opportunity Report Content",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "founder_brief_ref", "candidates", "recommended_candidate_index", "scoring_method"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "founder_brief_ref": { "$ref": "common.schema.json#/$defs/reference" },
    "candidates": {
      "type": "array",
      "minItems": 1,
      "maxItems": 50,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["problem", "target_user", "pain_score", "frequency_score", "budget_score", "ai_advantage_score", "mvp_feasibility_score", "founder_fit_score", "total_score", "assumptions", "risks"],
        "properties": {
          "problem": { "type": "string", "minLength": 1, "maxLength": 1000 },
          "target_user": { "type": "string", "minLength": 1, "maxLength": 300 },
          "pain_score": { "type": "integer", "minimum": 0, "maximum": 10 },
          "frequency_score": { "type": "integer", "minimum": 0, "maximum": 10 },
          "budget_score": { "type": "integer", "minimum": 0, "maximum": 10 },
          "ai_advantage_score": { "type": "integer", "minimum": 0, "maximum": 10 },
          "mvp_feasibility_score": { "type": "integer", "minimum": 0, "maximum": 10 },
          "founder_fit_score": { "type": "integer", "minimum": 0, "maximum": 10 },
          "total_score": { "type": "integer", "minimum": 0, "maximum": 60 },
          "assumptions": { "$ref": "common.schema.json#/$defs/stringList" },
          "risks": { "$ref": "common.schema.json#/$defs/stringList" }
        }
      }
    },
    "recommended_candidate_index": { "type": "integer", "minimum": 0 },
    "scoring_method": { "const": "unweighted_sum_v1" }
  }
}
