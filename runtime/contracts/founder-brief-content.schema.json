{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://founderos.dev/contracts/founder-brief-content.schema.json",
  "title": "FounderOS Founder Brief Content",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "founder_profile", "startup_context", "assumptions", "risks", "open_questions", "next_recommended_workflow"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "founder_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "background", "domain_expertise", "technical_skills", "business_skills", "available_time_per_week", "available_budget"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 200 },
        "background": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "domain_expertise": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1, "uniqueItems": true },
        "technical_skills": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "business_skills": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "available_time_per_week": { "type": "integer", "minimum": 1, "maximum": 168 },
        "available_budget": {
          "type": "object",
          "additionalProperties": false,
          "required": ["amount", "currency"],
          "properties": {
            "amount": { "type": "number", "minimum": 0 },
            "currency": { "type": "string", "pattern": "^[A-Z]{3}$" }
          }
        }
      }
    },
    "startup_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["domain", "target_users", "known_problem_area", "constraints", "success_definition"],
      "properties": {
        "domain": { "type": "string", "minLength": 1, "maxLength": 200 },
        "target_users": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1, "uniqueItems": true },
        "known_problem_area": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "constraints": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "success_definition": { "type": "string", "minLength": 1, "maxLength": 2000 }
      }
    },
    "assumptions": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "risks": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "open_questions": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "next_recommended_workflow": { "const": "Discovery Workflow" }
  }
}
