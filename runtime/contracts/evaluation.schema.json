{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://founderos.dev/contracts/evaluation.schema.json",
  "title": "FounderOS Evaluation",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "project_ref", "target_ref", "evaluation_type", "status", "evaluator", "criteria", "outcome", "created_at", "completed_at"],
  "properties": {
    "id": { "$ref": "common.schema.json#/$defs/canonicalId", "pattern": "^evl_" },
    "project_ref": { "$ref": "common.schema.json#/$defs/reference" },
    "target_ref": { "$ref": "common.schema.json#/$defs/reference" },
    "evaluation_type": { "type": "string", "enum": ["schema", "quality_gate", "evidence", "safety", "human_review"] },
    "status": { "type": "string", "enum": ["completed", "errored"] },
    "evaluator": { "$ref": "common.schema.json#/$defs/actor" },
    "criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["criterion_id", "description", "passed"],
        "properties": {
          "criterion_id": { "type": "string", "pattern": "^[a-z][a-z0-9_]{1,63}$" },
          "description": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
          "passed": { "type": "boolean" },
          "score": { "$ref": "common.schema.json#/$defs/confidenceScore" },
          "evidence_refs": { "$ref": "common.schema.json#/$defs/referenceList" },
          "notes": { "type": "string" }
        }
      }
    },
    "outcome": { "type": "string", "enum": ["pass", "fail", "error"] },
    "confidence_score": { "$ref": "common.schema.json#/$defs/confidenceScore" },
    "summary": { "type": "string" },
    "created_at": { "$ref": "common.schema.json#/$defs/utcTimestamp" },
    "completed_at": { "$ref": "common.schema.json#/$defs/utcTimestamp" },
    "metadata": { "$ref": "common.schema.json#/$defs/metadata" }
  }
}
