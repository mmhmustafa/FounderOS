{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://founderos.dev/contracts/workflow.schema.json",
  "title": "FounderOS Workflow Definition",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "version", "status", "name", "purpose", "entry_state", "exit_states", "steps", "failure_policy", "created_at", "updated_at"],
  "properties": {
    "id": { "$ref": "common.schema.json#/$defs/canonicalId", "pattern": "^wfl_" },
    "version": { "$ref": "common.schema.json#/$defs/semver" },
    "status": { "type": "string", "enum": ["draft", "active", "deprecated", "retired"] },
    "name": { "type": "string", "minLength": 1, "maxLength": 160 },
    "purpose": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
    "entry_state": { "$ref": "common.schema.json#/$defs/stateCode" },
    "exit_states": { "type": "array", "items": { "$ref": "common.schema.json#/$defs/stateCode" }, "minItems": 1, "uniqueItems": true },
    "required_artifact_types": { "$ref": "common.schema.json#/$defs/stringList" },
    "produced_artifact_types": { "$ref": "common.schema.json#/$defs/stringList" },
    "agent_refs": { "$ref": "common.schema.json#/$defs/referenceList" },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["step_id", "sequence", "name", "action_type", "on_failure"],
        "properties": {
          "step_id": { "type": "string", "pattern": "^[a-z][a-z0-9_]{1,63}$" },
          "sequence": { "type": "integer", "minimum": 1 },
          "name": { "type": "string", "minLength": 1 },
          "action_type": { "type": "string", "enum": ["collect_input", "invoke_agent", "evaluate", "request_approval", "record_decision", "request_transition"] },
          "agent_ref": { "$ref": "common.schema.json#/$defs/reference" },
          "required_artifact_types": { "$ref": "common.schema.json#/$defs/stringList" },
          "produced_artifact_types": { "$ref": "common.schema.json#/$defs/stringList" },
          "on_failure": { "type": "string", "enum": ["pause", "retry", "fail", "request_human", "recover"] }
        }
      }
    },
    "quality_gate_ids": { "$ref": "common.schema.json#/$defs/stringList" },
    "success_criteria": { "$ref": "common.schema.json#/$defs/stringList" },
    "failure_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_attempts", "terminal_behavior"],
      "properties": {
        "max_attempts": { "type": "integer", "minimum": 1, "maximum": 10 },
        "terminal_behavior": { "type": "string", "enum": ["pause", "fail", "request_human"] },
        "recovery_action": { "type": "string", "minLength": 1 }
      }
    },
    "next_workflow_refs": { "$ref": "common.schema.json#/$defs/referenceList" },
    "created_at": { "$ref": "common.schema.json#/$defs/utcTimestamp" },
    "updated_at": { "$ref": "common.schema.json#/$defs/utcTimestamp" },
    "metadata": { "$ref": "common.schema.json#/$defs/metadata" }
  }
}
