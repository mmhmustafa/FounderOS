{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://founderos.dev/contracts/authorization/policy-rule.schema.json",
  "title": "FounderOS PolicyRule Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id", "version", "status", "name", "effect", "priority", "actor_types",
    "actions", "resource_types", "conditions", "obligations", "created_at", "updated_at"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^prl_[0-7][0-9A-HJKMNP-TV-Z]{25}$" },
    "version": { "$ref": "authorization-common.schema.json#/$defs/semver" },
    "status": { "type": "string", "enum": ["active", "disabled", "deprecated"] },
    "name": { "type": "string", "minLength": 1, "maxLength": 200 },
    "description": { "type": "string", "minLength": 1, "maxLength": 1000 },
    "effect": { "$ref": "authorization-common.schema.json#/$defs/effect" },
    "priority": { "type": "integer", "minimum": 0, "maximum": 1000000 },
    "actor_types": {
      "type": "array",
      "items": { "$ref": "authorization-common.schema.json#/$defs/actorType" },
      "minItems": 1,
      "uniqueItems": true
    },
    "actions": {
      "type": "array",
      "items": { "$ref": "authorization-common.schema.json#/$defs/action" },
      "minItems": 1,
      "uniqueItems": true
    },
    "resource_types": {
      "type": "array",
      "items": { "$ref": "authorization-common.schema.json#/$defs/resourceType" },
      "minItems": 1,
      "uniqueItems": true
    },
    "conditions": {
      "type": "array",
      "items": { "$ref": "authorization-common.schema.json#/$defs/condition" },
      "maxItems": 25
    },
    "obligations": {
      "type": "array",
      "items": { "type": "string", "minLength": 1, "maxLength": 200 },
      "uniqueItems": true
    },
    "created_at": { "$ref": "authorization-common.schema.json#/$defs/utcTimestamp" },
    "updated_at": { "$ref": "authorization-common.schema.json#/$defs/utcTimestamp" }
  }
}
