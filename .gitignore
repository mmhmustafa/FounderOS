# ------------------------------------------------
# FounderOS Generated Deliverables
# ------------------------------------------------

deliverables/*
!deliverables/.gitkeep
# ------------------------------------------------
# Atlas CLI Generated Artifacts (demo and live runs)
# ------------------------------------------------

/atlas_topology.html
/topology_snapshot.json
/morning_brief.md
/change_report.json
/change_report.md
/config_change_report.json
/config_change_report.md
/state_change_report.json
/state_change_report.md
/intelligence_report.json
/intelligence_report.md
/root_cause_report.json
/root_cause_report.md
/prediction_report.json
/prediction_report.md
/path_investigation_report.json
/path_investigation_report.md
/path_investigations.json
/dashboard.html
/incident_report.json
/incident_report.md
/timeline.md

# Atlas discovery history (local network memory; contains configs)
/.atlas/

# Enterprise Memory store written to CWD when discovery runs outside a profile
# dir. Content-addressed blobs of raw evidence + device configs — never commit.
/enterprise-memory/

# Collected device configurations are sensitive material; never commit them.
/configs/

# Hand-off zips built to share one PR's work. They are a snapshot of the tree,
# so committing one puts a second, silently ageing copy of the code in history
# — pr-046-cortex.zip got in this way, via `git add -A`. This rule does not
# untrack the ones already committed; `git rm --cached` does that.
*.zip
